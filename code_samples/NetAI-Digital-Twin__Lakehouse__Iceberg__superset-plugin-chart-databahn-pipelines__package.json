{
  "name": "superset-plugin-chart-databahn-pipelines",
  "version": "0.1.0",
  "description": "Superset visualization plugin for Databahn pipeline/workflow monitoring — run history, success/failure rates, durations, and more.",
  "sideEffects": false,
  "main": "lib/index.js",
  "module": "esm/index.js",
  "files": [
    "esm",
    "lib"
  ],
  "repository": "",
  "keywords": [
    "superset",
    "plugin",
    "chart",
    "databahn",
    "pipeline",
    "workflow"
  ],
  "author": "",
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc --outDir lib --module commonjs",
    "build:esm": "tsc --outDir esm --module esnext",
    "dev": "tsc --outDir esm --module esnext --watch",
    "test": "jest",
    "clean": "rm -rf lib esm"
  },
  "dependencies": {
    "@superset-ui/core": "latest",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@superset-ui/core": "*",
    "react": "^16.13.1 || ^17.0.0 || ^18.0.0"
  }
}
